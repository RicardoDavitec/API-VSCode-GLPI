# Exemplo — copiar para ~/.secrets/glpi.env (chmod 600)
# Nunca versionar o arquivo real com tokens.
#
# Formato dotenv (KEY=VALUE). Comentários com #.
# Ambiente ativo: GLPI_ENV=prod|homolog  (ou flag CLI --env=homolog)

GLPI_USER_TOKEN=seu_user_token_aqui
GLPI_APP_TOKEN=seu_app_token_aqui

# Opcional: tokens so da homologacao (se o App-Token de prod nao existir la)
# GLPI_USER_TOKEN_HOMOLOG=
# GLPI_APP_TOKEN_HOMOLOG=

# Produção (PMF Franca — exemplo)
GLPI_API_URL_PROD=https://suporte.franca.sp.gov.br/apirest.php
GLPI_UI_URL_PROD=https://suporte.franca.sp.gov.br

# Homologação
GLPI_API_URL_HOMOLOG=https://suporte-homolog.franca.sp.gov.br/apirest.php
GLPI_UI_URL_HOMOLOG=https://suporte-homolog.franca.sp.gov.br

# Default se GLPI_ENV nao for informado
GLPI_ENV_DEFAULT=prod
