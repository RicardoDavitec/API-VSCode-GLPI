# Instancia GLPI do produto (copiar para .glpi/instance.yaml — nao versionar se tiver URL interna sensivel)

preset: api-vscode-glpi
environment: prod

glpi:
  api_url: "https://suporte.franca.sp.gov.br/apirest.php"
  ui_url: "https://suporte.franca.sp.gov.br"
  require_app_token: true

environments:
  prod:
    api_url: "https://suporte.franca.sp.gov.br/apirest.php"
  homolog:
    api_url: "https://suporte-homolog.franca.sp.gov.br/apirest.php"

secrets:
  file: "~/.secrets/glpi.env"
  format: dotenv

states:
  map_file: ".glpi/maps/states.json"

workflow:
  phase_template: corporate-phases
