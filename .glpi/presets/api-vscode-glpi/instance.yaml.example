# Preset api-vscode-glpi — triangulo VSCode/Cursor ↔ Git ↔ GLPI
# Exemplificacao PMF Franca (suporte.franca.sp.gov.br); adapte api_url ao seu GLPI.

preset: api-vscode-glpi
label: "API-VSCode-GLPI (PMF Franca — exemplo)"

glpi:
  api_url: "https://suporte.franca.sp.gov.br/apirest.php"
  ui_url: "https://suporte.franca.sp.gov.br"
  require_app_token: true

secrets:
  file: "~/.secrets/GLPI-tokens.txt"
  format: pmf

states:
  map_file: ".glpi/maps/states.json"
  auto_discover: true

workflow:
  hierarchy: s_p
  phase_template: corporate-phases

# Exemplo PMF (nao usar como default obrigatorio — preencher no project.yaml do produto):
# ticket_id: 10554  (Samu Operacional)
# project_id: 72      (Desenvolvimento PMF SIGS-Samu)
